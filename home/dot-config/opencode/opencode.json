{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/github.com/**": "allow"
    }
  },
  "mcp": {
    "uidotsh": {
      "type": "remote",
      "url": "https://ui.sh/mcp?agent=opencode",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:UIDOTSH_TOKEN}"
      }
    }
  }
}
