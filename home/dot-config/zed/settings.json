{
  "agent_servers": {
    "opencode": {
      "type": "registry"
    }
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "theme": "Catppuccin Macchiato",
  "vim_mode": true,
  "buffer_font_size": 12,
  "ui_font_size": 15,
  "terminal": {
    "font_size": 12,
    "dock": "bottom",
  },
  "relative_line_numbers": "enabled",
  "vim": {
    "use_system_clipboard": "always",
    "toggle_relative_line_numbers": true,
  },
}
